# =========================================
# Chat 推理：默认接入小米 MiMo 开放平台
# =========================================
# 申请地址：https://platform.xiaomimimo.com
# Token Plan 申请：https://100t.xiaomimimo.com

OPENAI_API_KEY=你的_MiMo_API_Key

# Base URL 二选一：
# - 使用 Token Plan 订阅：https://token-plan-cn.xiaomimimo.com/v1
# - 使用按量计费余额：    https://api.xiaomimimo.com/v1
OPENAI_BASE_URL=https://api.xiaomimimo.com/v1

# 推荐模型：
# - mimo-v2.5-pro   主打 Agent / Coding，100 万 token 上下文（强烈推荐）
# - mimo-v2.5       全模态版本
OPENAI_MODEL=mimo-v2.5-pro

# =========================================
# Embedding 配置
# =========================================
# 如果 MiMo 提供 embedding 模型，可填同名；
# 否则可填任意 OpenAI 兼容 embedding 服务（不要与 chat 共用 base_url 时，
# 请改用下方 EMBED_API_KEY / 在代码 config 中设置 embed_base_url）。
EMBED_MODEL=text-embedding-3-small
EMBED_DIMS=1024

# 可选：embedding 单独走另一个 OpenAI 兼容服务时使用
# EMBED_API_KEY=your_embed_api_key
